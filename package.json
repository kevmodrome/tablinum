{
  "name": "tablinum",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "bun run vitest run",
    "test:watch": "bun run vitest",
    "validate": "bun run scripts/validate.ts",
    "demo": "bun run examples/vanilla/serve.ts",
    "demo:svelte": "cd examples/svelte && bun run dev",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "effect": "4.0.0-beta.28",
    "idb": "^8.0.3",
    "nostr-tools": "^2.23.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@effect/vitest": "4.0.0-beta.28",
    "@j178/prek": "latest",
    "@types/bun": "^1.3.10",
    "fake-indexeddb": "^6.2.5",
    "oxfmt": "latest",
    "oxlint": "^1.51.0",
    "svelte": "^5.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  }
}
