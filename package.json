{
  "name": "tablinum-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "bun run --filter tablinum dev",
    "build": "bun run --filter tablinum build",
    "test": "bun run vitest run",
    "test:watch": "bun run vitest",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "validate": "bun run scripts/validate.ts",
    "demo": "bun run --filter tablinum-example-vanilla dev",
    "demo:svelte": "bun run --filter tablinum-svelte-example dev",
    "web": "bun run --filter tablinum-web dev",
    "web:build": "bun run --filter tablinum-web build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "relays": "docker compose up -d",
    "relays:down": "docker compose down",
    "relays:clean": "docker compose down -v"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@j178/prek": "0.3.5",
    "oxfmt": "0.38.0",
    "oxlint": "^1.53.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
