{
  "name": "tablinum",
  "version": "0.6.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevmodrome/tablinum.git",
    "directory": "packages/tablinum"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.svelte.d.ts",
      "svelte": "./dist/svelte/index.svelte.js",
      "import": "./dist/svelte/index.svelte.js"
    }
  },
  "scripts": {
    "dev": "npx tsx src/main.ts",
    "build": "esbuild src/index.ts --outdir=dist --format=esm --bundle --packages=external && esbuild src/svelte/index.svelte.ts --outdir=dist/svelte --format=esm --bundle --packages=external && tsc -p tsconfig.build.json --noCheck && tsc -p tsconfig.build.svelte.json --noCheck"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "effect": "4.0.0-beta.31",
    "idb": "^8.0.3",
    "nostr-tools": "^2.23.3"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.31",
    "esbuild": "^0.24.0",
    "fake-indexeddb": "^6.2.5",
    "svelte": "^5.53.10"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  }
}
